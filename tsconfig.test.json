{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "out/test",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["test/**/*.ts"],
  "exclude": ["node_modules"]
}
